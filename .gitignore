# ============================================================
# NeedNow AI — Production .gitignore
# ============================================================

# ==================== Environment Variables ====================
.env
.env.local
.env.development
.env.production
.env.staging
.env.*.local

# Keep example env files
!.env.example

# ==================== Python ====================
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual Environments
venv/
.venv/
env/
ENV/

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# MyPy
.mypy_cache/

# ==================== Node.js ====================
node_modules/
.next/
out/
.turbo/
.vercel/

# ==================== Build / Generated ====================
dist/
build/
*.tsbuildinfo

# ==================== Data & ML Artifacts ====================
# Large dataset files (generated by scripts)
backend/datasets/
backend/faiss_indexes/
*.index
*.npy
*.pkl
*.pickle

# ChromaDB
chroma_db/
*.sqlite3

# ==================== Logs ====================
*.log
logs/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ==================== OS Files ====================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.swp
*.swo
*~

# ==================== IDE ====================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ==================== Docker ====================
*.pid

# ==================== Database ====================
*.db
*.sqlite3

# ==================== Temporary Files ====================
tmp/
temp/
*.tmp

# ==================== Uploads ====================
uploads/

# ==================== Debug/Trace Reports ====================
# Reports are in docs/ folder — these patterns exclude stray root-level ones
/root_cause.md
/chat_debug_report.md
